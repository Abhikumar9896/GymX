{
  "expo": {
    "name": "GymX",
    "slug": "gymx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "gymapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gymx.athlete",
      "infoPlist": {
        "NSHealthShareUsageDescription": "GymX needs to access your step count to track your daily physical activity.",
        "NSHealthUpdateUsageDescription": "GymX needs permission to update your health data.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E293B",
        "foregroundImage": "./assets/images/logo.png"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS",
        "READ_HEALTH_DATA",
        "WRITE_HEALTH_DATA"
      ],
      "package": "com.gymx.athlete",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ],
      "expo-notifications",
      "expo-task-manager",
      "expo-background-fetch",
      "@react-native-community/datetimepicker",
      [
        "react-native-health",
        {
          "NSHealthShareUsageDescription": "GymX needs to access your step count to track your daily physical activity.",
          "NSHealthUpdateUsageDescription": "GymX needs permission to update your health data."
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "extraMavenRepos": [
              "https://maven.google.com"
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2af180fc-f473-4bf5-9ce7-8eaf9d69ad5b"
      }
    }
  }
}
